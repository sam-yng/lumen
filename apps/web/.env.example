# Supabase local stack (from `bunx supabase status`).
# Copy to .env.local and fill with your local values. Never commit .env.local.

# Public (client-safe) — inlined into the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# App origin — absolute URL of the deployed app. Used for auth redirect links
# (email confirmation / password reset / OAuth). Dev defaults to
# http://localhost:3000; MUST be set in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only — never expose to the client. Used by the transcription worker
# (M4), which connects with the secret/service role and BYPASSES RLS, so it
# must scope every query by user_id manually. See SECURITY.md.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Transcription worker / queue (M4).
PG_BOSS_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
TRANSCRIPTION_STORAGE_BUCKET=library-files
WHISPER_MODEL=base.en
TRANSCRIPTION_TMP_DIR=/tmp/lumen-transcription

# Speaker diarization (v3 m3) + live-session speaker labels (v4 m4). Off by
# default; degrades to null speakers on any error. Fetch the ONNX models with
# `bun run worker:diarization-models` (writes to .models/diarization/).
DIARIZATION_ENABLED=false
DIARIZATION_SEGMENTATION_MODEL_PATH=.models/diarization/segmentation.onnx
DIARIZATION_EMBEDDING_MODEL_PATH=.models/diarization/embedding.onnx
# Optional tuning: cluster threshold (0–1) and fixed speaker count (-1 = auto).
# DIARIZATION_CLUSTER_THRESHOLD=0.9
# DIARIZATION_NUM_SPEAKERS=-1

# Stale live-session sweep (v4 m5): a live recording with no segment activity
# for this many minutes is finalized or expired by the cron job.
LIVE_SESSION_STALE_MINUTES=45

# ── Production note ───────────────────────────────────────────────────────────
# In prod these are injected by the host dashboard, never committed. See
# docs/exec-plans/active/production/prod-readiness/DEPLOY.md for the full matrix.
#   Vercel (app):     NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY,
#                     NEXT_PUBLIC_APP_URL, SUPABASE_SECRET_KEY, PG_BOSS_DATABASE_URL
#   Railway (worker): SUPABASE_SECRET_KEY, PG_BOSS_DATABASE_URL,
#                     TRANSCRIPTION_STORAGE_BUCKET, WHISPER_MODEL,
#                     TRANSCRIPTION_TMP_DIR, DIARIZATION_ENABLED,
#                     DIARIZATION_SEGMENTATION_MODEL_PATH,
#                     DIARIZATION_EMBEDDING_MODEL_PATH, LIVE_SESSION_STALE_MINUTES
# PG_BOSS_DATABASE_URL must be the DIRECT Postgres connection (not the
# transaction pooler) — pg-boss holds long-lived connections / LISTEN.

RESEND_API_KEY=resend_api_key_xxx