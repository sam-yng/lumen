{
  "name": "lumen",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "biome check . && bun run check:plans && turbo run typecheck test",
    "check:plans": "bun run scripts/check-plan-lifecycle.ts",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "bun run --filter @lumen/web test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "turbo": "^2"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
